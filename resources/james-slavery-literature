  /* Production */
  .task{background:linear-gradient(135deg,var(--teal-deep),var(--teal));color:#F6F1E6;border-radius:14px;padding:clamp(20px,4vw,30px);box-shadow:var(--shadow)}
  .task h2{color:#FBF8F1}
  .task .sub{color:rgba(246,241,230,.78)}
  .task ul{list-style:none;margin-top:14px}
  .task li{padding:10px 0;border-top:1px solid rgba(246,241,230,.18);font-size:.93rem;display:flex;gap:11px}
  .task li:first-of-type{border-top:none}
  .task li .b{font-family:"Fraunces";font-style:italic;color:#F0C9B8;flex-shrink:0}

