  /* The argument tab */
  .full-line{font-family:"Fraunces";font-style:italic;font-size:clamp(1.05rem,2.7vw,1.28rem);line-height:1.7;color:#322D26;border-left:3px solid var(--clay);padding:6px 0 6px 18px;margin:6px 0 22px}
  .move{display:flex;gap:14px;margin-bottom:12px;cursor:pointer;align-items:flex-start;border:1px solid var(--line);border-radius:12px;padding:14px 16px;background:var(--cream);transition:.15s}
