<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Listening lesson — Why one person can't be everything (Esther Perel × Oprah)</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,300..900,0..100,0..1;1,9..144,300..900,0..100,0..1&family=Lora:ital,wght@0,400..700;1,400..600&display=swap" rel="stylesheet">
<style>
  :root {
    --paper: #f4ede0;
    --paper-deep: #ebe1cf;
    --paper-warm: #f0e6d4;
    --ink: #1d2438;
    --ink-soft: #5a607a;
    --accent: #2d6a4f;
    --highlight: #a83232;
    --gold: #b58040;
    --rule: #c9b896;
    --shadow: rgba(29, 36, 56, 0.08);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--paper);
    color: var(--ink);
    font-family: 'Lora', Georgia, serif;
    font-size: 16px;
    line-height: 1.65;
    min-height: 100vh;
    background-image:
      radial-gradient(ellipse at 15% 25%, rgba(45, 106, 79, 0.04) 0%, transparent 50%),
      radial-gradient(ellipse at 85% 75%, rgba(168, 50, 50, 0.04) 0%, transparent 50%);
    -webkit-font-smoothing: antialiased;
  }

  .container {
    max-width: 980px;
    margin: 0 auto;
    padding: 56px 32px 80px;
  }

  /* === Header === */
  header {
    border-bottom: 1px solid var(--rule);
    padding-bottom: 32px;
    margin-bottom: 48px;
  }

  .eyebrow {
    font-family: 'Lora', serif;
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 14px;
  }

  h1 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 400;
    font-style: italic;
    font-size: clamp(44px, 7vw, 78px);
    line-height: 0.98;
    letter-spacing: -0.025em;
    color: var(--ink);
    font-variation-settings: "SOFT" 80, "WONK" 1;
  }

  h1 .accent { color: var(--accent); }

  .subtitle {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: clamp(16px, 2vw, 20px);
    color: var(--ink-soft);
    margin-top: 16px;
    max-width: 640px;
  }

  .episode-meta {
    margin-top: 24px;
    padding-top: 22px;
    border-top: 1px dashed var(--rule);
    font-family: 'Lora', serif;
    font-size: 13px;
    color: var(--ink-soft);
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .episode-meta strong { color: var(--ink); font-weight: 500; }

  /* === Generic section === */
  section { margin-bottom: 56px; }

  .section-label {
    font-family: 'Lora', serif;
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 10px;
  }

  h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 400;
    font-style: italic;
    font-size: clamp(28px, 4vw, 38px);
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: 20px;
    letter-spacing: -0.015em;
    font-variation-settings: "SOFT" 80;
  }

  .prose {
    font-family: 'Lora', serif;
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink);
    margin-bottom: 18px;
    max-width: 740px;
  }

  /* === Overview / orientation === */
  .orientation {
    background: var(--paper-deep);
    border: 1px solid var(--rule);
    border-radius: 2px;
    padding: 28px 32px;
  }

  .orientation-title {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 22px;
    color: var(--ink);
    margin-bottom: 14px;
    font-variation-settings: "SOFT" 80;
  }

  .orientation .prose { font-size: 15px; max-width: none; }
  .orientation .prose:last-child { margin-bottom: 0; }

  /* === Warm-up === */
  .warmup-list {
    list-style: none;
    margin-top: 14px;
  }

  .warmup-list li {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink);
    padding: 10px 0 10px 24px;
    border-bottom: 1px dashed rgba(201, 184, 150, 0.55);
    position: relative;
  }

  .warmup-list li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .warmup-list li:last-child { border-bottom: none; }

  /* === Segment === */
  .segment {
    margin-bottom: 64px;
  }

  .segment-header {
    background: var(--paper-deep);
    border: 1px solid var(--rule);
    border-left: 4px solid var(--accent);
    border-radius: 2px;
    padding: 22px 28px;
    margin-bottom: 28px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 24px;
    align-items: center;
  }

  .segment-letter {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 54px;
    color: var(--accent);
    line-height: 1;
    font-variation-settings: "SOFT" 80;
  }

  .segment-title-wrap { display: flex; flex-direction: column; gap: 4px; }

  .segment-meta {
    font-family: 'Lora', serif;
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-weight: 600;
  }

  .segment-title {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(22px, 3vw, 28px);
    color: var(--ink);
    line-height: 1.15;
    font-variation-settings: "SOFT" 80;
  }

  .segment-time {
    font-family: 'Lora', serif;
    font-style: italic;
    font-size: 14px;
    color: var(--ink-soft);
    text-align: right;
    line-height: 1.4;
  }

  .segment-time strong { color: var(--ink); font-weight: 500; font-style: normal; display: block; font-size: 15px; }

  /* === Block within a segment === */
  .block {
    margin-bottom: 22px;
  }

  .block-label {
    font-family: 'Lora', serif;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-weight: 600;
    margin-bottom: 8px;
  }

  .block-body {
    font-family: 'Lora', serif;
    font-size: 15.5px;
    line-height: 1.65;
    color: var(--ink);
  }

  /* === Pre-vocab === */
  .vocab {
    background: var(--paper-warm);
    border: 1px solid var(--rule);
    border-radius: 2px;
    padding: 18px 22px;
  }

  .vocab dl { display: grid; gap: 8px; }

  .vocab dt {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 500;
    color: var(--accent);
    font-size: 15.5px;
    display: inline;
  }

  .vocab dd {
    display: inline;
    font-family: 'Lora', serif;
    font-size: 14.5px;
    color: var(--ink);
    margin-left: 6px;
  }

  .vocab .vocab-row {
    padding: 4px 0;
    border-bottom: 1px dashed rgba(201, 184, 150, 0.45);
  }
  .vocab .vocab-row:last-child { border-bottom: none; }

  /* === Listen-for prompt === */
  .listen-for {
    border-left: 3px solid var(--gold);
    background: rgba(181, 128, 64, 0.06);
    padding: 14px 20px;
  }

  .listen-for .block-label { color: var(--gold); }

  .listen-for-text {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 17px;
    color: var(--ink);
    font-variation-settings: "SOFT" 80;
  }

  /* === Pause prompts (the live cue box) === */
  .pause-prompts {
    background: rgba(45, 106, 79, 0.06);
    border: 1.5px solid var(--accent);
    border-radius: 2px;
    padding: 20px 24px;
  }

  .pause-label {
    font-family: 'Lora', serif;
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 700;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .pause-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border: 1.5px solid var(--accent);
    border-radius: 50%;
    color: var(--accent);
    font-size: 10px;
    font-family: 'Lora', serif;
    font-weight: 600;
    letter-spacing: 0;
  }

  .pause-list { list-style: none; }

  .pause-list li {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 16px;
    line-height: 1.5;
    color: var(--ink);
    padding: 12px 0 12px 28px;
    border-bottom: 1px dashed rgba(45, 106, 79, 0.25);
    position: relative;
  }

  .pause-list li:last-child { border-bottom: none; }

  .pause-list li::before {
    content: "▸";
    position: absolute;
    left: 0;
    top: 12px;
    color: var(--accent);
    font-style: normal;
    font-size: 14px;
  }

  .pause-when {
    font-family: 'Lora', serif;
    font-style: normal;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    display: block;
    margin-bottom: 2px;
  }

  /* === Comprehension check === */
  .check {
    background: var(--paper-deep);
    border: 1px solid var(--rule);
    border-radius: 2px;
    padding: 18px 22px;
  }

  .check ol {
    list-style: none;
    counter-reset: q;
  }

  .check li {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 15.5px;
    line-height: 1.55;
    color: var(--ink);
    padding: 8px 0 8px 32px;
    border-bottom: 1px dashed rgba(201, 184, 150, 0.5);
    position: relative;
    counter-increment: q;
  }

  .check li::before {
    content: counter(q);
    position: absolute;
    left: 0;
    top: 8px;
    font-family: 'Lora', serif;
    font-size: 11px;
    color: var(--ink-soft);
    font-style: normal;
    letter-spacing: 0.04em;
    font-weight: 600;
    padding-top: 2px;
  }

  .check li:last-child { border-bottom: none; }

  /* === Discussion === */
  .discuss {
    border-left: 3px solid var(--highlight);
    padding: 6px 0 6px 20px;
  }

  .discuss .block-label { color: var(--highlight); }

  .discuss ul { list-style: none; }

  .discuss li {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink);
    padding: 8px 0;
    border-bottom: 1px dashed rgba(168, 50, 50, 0.2);
  }

  .discuss li:last-child { border-bottom: none; }

  /* === Level scaffolds === */
  .levels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-top: 8px;
  }

  .level-card {
    padding: 16px 20px;
    border-radius: 2px;
    border: 1px dashed var(--rule);
    background: var(--paper-warm);
  }

  .level-card.b1 { border-color: var(--gold); }
  .level-card.c1 { border-color: var(--accent); }

  .level-tag {
    font-family: 'Lora', serif;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .level-card.b1 .level-tag { color: var(--gold); }
  .level-card.c1 .level-tag { color: var(--accent); }

  .level-body {
    font-family: 'Lora', serif;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--ink);
    font-style: italic;
  }

  .level-body em.fr { font-style: italic; color: var(--ink-soft); }

  /* === Wrap-up === */
  .wrapup {
    background: var(--paper-deep);
    border: 1px solid var(--rule);
    border-top: 3px solid var(--highlight);
    border-radius: 2px;
    padding: 32px 36px;
  }

  .wrapup-title {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 26px;
    color: var(--ink);
    margin-bottom: 8px;
    font-variation-settings: "SOFT" 80;
  }

  .wrapup-intro {
    font-family: 'Lora', serif;
    font-style: italic;
    font-size: 14.5px;
    color: var(--ink-soft);
    margin-bottom: 20px;
  }

  .wrapup-list { list-style: none; }

  .wrapup-list li {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink);
    padding: 14px 0 14px 32px;
    border-bottom: 1px dashed rgba(201, 184, 150, 0.5);
    position: relative;
  }

  .wrapup-list li:last-child { border-bottom: none; }

  .wrapup-list li::before {
    content: counter(wrap);
    counter-increment: wrap;
    position: absolute;
    left: 0;
    top: 14px;
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 18px;
    color: var(--highlight);
    font-weight: 500;
  }

  .wrapup-list { counter-reset: wrap; }

  /* === Take-home === */
  .takehome {
    text-align: center;
    padding: 28px 24px;
    border: 1px dashed var(--rule);
    border-radius: 2px;
    background: var(--paper-warm);
  }

  .takehome-label {
    font-family: 'Lora', serif;
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-weight: 600;
    margin-bottom: 12px;
  }

  .takehome-text {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 19px;
    line-height: 1.4;
    color: var(--ink);
    max-width: 560px;
    margin: 0 auto;
    font-variation-settings: "SOFT" 80;
  }

  /* === Footer === */
  footer {
    margin-top: 64px;
    padding-top: 28px;
    border-top: 1px solid var(--rule);
    text-align: center;
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 13px;
    color: var(--ink-soft);
  }

  footer .ornament { color: var(--rule); margin: 0 10px; }

  /* === Responsive === */
  @media (max-width: 760px) {
    .segment-header {
      grid-template-columns: 1fr;
      gap: 12px;
      text-align: center;
    }
    .segment-time { text-align: center; }
    .levels { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .container { padding: 40px 18px 60px; }
    .segment-header { padding: 20px 22px; }
    .orientation, .wrapup { padding: 24px 22px; }
  }
  @media print {
    body { background: white; }
    .segment, .pause-prompts, .check, .vocab, .listen-for { break-inside: avoid; }
  }
</style>
